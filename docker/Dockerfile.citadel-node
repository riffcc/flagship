# Pre-built base image for Citadel nodes
# Includes inotify-tools so nodes don't need to apt-get at runtime
FROM debian:trixie-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends inotify-tools && \
    rm -rf /var/lib/apt/lists/*

# Default command just waits - overridden by compose
CMD ["sleep", "infinity"]
