# Citadel Lens Node Connection
# Point to the lens-node running in citadel directory
VITE_API_URL=https://citadel.island.riff.cc/api/v1
VITE_ARCHIVIST_API_URL=https://cdn.riff.cc
VITE_ARCHIVIST_GATEWAY=https://cdn.riff.cc

# Librarian Content Operations Daemon
VITE_LIBRARIAN_API_URL=http://localhost:7878

# Network Mode - use Citadel mesh
VITE_NETWORK_MODE=hybrid
VITE_USE_PEERBIT=false
VITE_USE_CITADEL=true

# Fallback to HTTP API
VITE_FALLBACK_ORDER=http
VITE_FALLBACK_TIMEOUT=2000
